rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{username} {
      // Creating: the new doc's uid field must match the signed-in user
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      // Reading/updating/deleting: the stored uid field must match
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;

      // Queue — public read (for /queue and /overlay pages), owner write
      match /queue/{docId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid;
      }

      // Donations — owner only
      match /donations/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid;
      }

      // History — owner only
      match /history/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid;
      }

      // Comment album — public read, owner write
      match /comment_album/{docId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid;
      }

      // Settings — owner only
      match /settings/{settingId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid;
      }

      // Packages — public read (for display), owner write
      match /packages/{packageId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid;
      }
    }
  }
}
